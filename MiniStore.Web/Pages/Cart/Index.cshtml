@page
@model MiniStore.Web.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Корзина";
}

<h1 class="page-title">Корзина</h1>

@if (!Model.Items.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🛒</div>
        <p class="fs-5 mb-3">Корзина пуста</p>
        <a href="/" class="btn btn-accent">Перейти в каталог</a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            @foreach (var item in Model.Items)
            {
                <div class="cart-item d-flex align-items-center gap-3">
                    <div class="flex-grow-1">
                        <p class="fw-semibold mb-0" style="font-size: 0.95rem;">@item.Name</p>
                        <small style="color: var(--text-muted);">@item.Price.ToString("C") за шт.</small>
                    </div>

                    <div class="qty-control d-flex align-items-center gap-0">
                        <form method="post" asp-page-handler="Decrease">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="qty-btn">−</button>
                        </form>
                        <span class="qty-display">@item.Quantity</span>
                        <form method="post" asp-page-handler="Increase">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="qty-btn">+</button>
                        </form>
                    </div>

                    <span class="fw-bold" style="min-width: 80px; text-align: right; color: var(--accent);">
                        @item.Total.ToString("C")
                    </span>

                    <form method="post" asp-page-handler="Remove">
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <button type="submit" class="btn-remove" title="Удалить">✕</button>
                    </form>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="summary-card">
                <h5 class="fw-bold mb-3">Итого</h5>
                <div class="d-flex justify-content-between mb-2" style="color: var(--text-muted); font-size: 0.9rem;">
                    <span>Позиций:</span>
                    <span>@Model.Items.Count</span>
                </div>
                <div class="d-flex justify-content-between mb-2" style="color: var(--text-muted); font-size: 0.9rem;">
                    <span>Товаров:</span>
                    <span>@Model.Items.Sum(i => i.Quantity) шт.</span>
                </div>
                <hr style="border-color: var(--shadow-dark);" />
                <div class="d-flex justify-content-between mb-4">
                    <span class="fw-bold fs-5">Сумма:</span>
                    <span class="fw-bold fs-5" style="color: var(--accent);">@Model.Items.Sum(i => i.Total).ToString("C")</span>
                </div>
                <form method="post" asp-page-handler="Checkout">
                    <button type="submit" class="btn btn-accent w-100 mb-2">Оформить заказ</button>
                </form>
                <a href="/" class="btn btn-nm w-100 text-center">Продолжить покупки</a>
            </div>
        </div>
    </div>
}
