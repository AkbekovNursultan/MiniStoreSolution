@page
@model MiniStore.Web.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = "Удалить категорию";
}

<h2>Удалить категорию</h2>

<div class="alert alert-warning mt-3" style="max-width: 400px;">
    Вы уверены что хотите удалить категорию <strong>@Model.Name</strong>?
</div>

<form method="post" style="max-width: 400px;">
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a href="/Categories" class="btn btn-secondary ms-2">Отмена</a>
</form>
