@page
@model MiniStore.Web.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Категории";
}

<h2>Категории</h2>
<a href="/Categories/Create" class="btn btn-primary mb-3">+ Добавить категорию</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model.Categories)
        {
            <tr>
                <td>@category.Id</td>
                <td>@category.Name</td>
                <td>
                    <a href="/Categories/Edit?id=@category.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <a href="/Categories/Delete?id=@category.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>
