@page
@model IndexModel
@{
    ViewData["Title"] = "Каталог";
    var icons = new Dictionary<string, string>
    {
        ["Электроника"] = "💻",
        ["Книги"] = "📚",
        ["Одежда"] = "👕",
        ["Спорт"] = "⚽",
        ["Дом"] = "🏠",
        ["Electronics"] = "💻",
        ["Books"] = "📚"
    };
}

<h1 class="page-title">Каталог товаров</h1>

<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="/" class="filter-pill @(Model.SelectedCategoryId == null ? "active" : "")">Все товары</a>
    @foreach (var cat in Model.Categories)
    {
        <a href="/?categoryId=@cat.Id"
           class="filter-pill @(Model.SelectedCategoryId == cat.Id ? "active" : "")">
            @cat.Name
        </a>
    }
</div>

@if (!Model.Products.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🛍️</div>
        <p class="fs-5 mb-3">В этой категории пока нет товаров</p>
        <a href="/" class="btn-accent btn">Смотреть все</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var product in Model.Products)
        {
            var catName = Model.Categories.FirstOrDefault(c => c.Id == product.CategoryId)?.Name ?? "";
            var icon = icons.TryGetValue(catName, out var i) ? i : "📦";
            <div class="col">
                <div class="nm-card h-100 p-3 d-flex flex-column">
                    <div class="product-icon">@icon</div>
                    <span class="category-badge">@catName</span>
                    <p class="product-name mb-1">@product.Name</p>
                    <p class="product-price mt-auto mb-3">@product.Price.ToString("C")</p>
                    <form method="post" asp-page-handler="AddToCart">
                        <input type="hidden" name="productId" value="@product.Id" />
                        <input type="hidden" name="name" value="@product.Name" />
                        <input type="hidden" name="price" value="@product.Price" />
                        <button type="submit" class="btn btn-accent w-100">В корзину</button>
                    </form>
                </div>
            </div>
        }
    </div>
}
