@page
@model MiniStore.Web.Pages.Orders.CreateModel
@{
    ViewData["Title"] = "Новый заказ";
}

<h2>Новый заказ</h2>

<form method="post" class="mt-3" style="max-width: 500px;">
    <div id="items-container">
        <div class="item-row d-flex gap-2 mb-2">
            <select name="ProductIds" class="form-select">
                <option value="">— товар —</option>
                @foreach (var p in Model.ProductOptions)
                {
                    <option value="@p.Value">@p.Text</option>
                }
            </select>
            <input name="Quantities" type="number" min="1" value="1" class="form-control" style="width: 100px;" />
        </div>
    </div>

    <button type="button" class="btn btn-outline-secondary btn-sm mb-3" onclick="addItem()">+ Добавить товар</button>

    <div>
        <button type="submit" class="btn btn-primary">Создать заказ</button>
        <a href="/Orders" class="btn btn-secondary ms-2">Отмена</a>
    </div>
</form>

<script>
    function addItem() {
        const container = document.getElementById('items-container');
        const first = container.querySelector('.item-row');
        const clone = first.cloneNode(true);
        clone.querySelector('select').value = '';
        clone.querySelector('input').value = '1';
        container.appendChild(clone);
    }
</script>
