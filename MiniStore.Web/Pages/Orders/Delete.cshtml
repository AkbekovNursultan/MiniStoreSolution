@page
@model MiniStore.Web.Pages.Orders.DeleteModel
@{
    ViewData["Title"] = "Удалить заказ";
}

<h2>Удалить заказ</h2>

<div class="alert alert-warning mt-3" style="max-width: 400px;">
    Вы уверены что хотите удалить заказ <strong>#@Model.Id</strong> от @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")?
</div>

<form method="post" style="max-width: 400px;">
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a href="/Orders" class="btn btn-secondary ms-2">Отмена</a>
</form>
