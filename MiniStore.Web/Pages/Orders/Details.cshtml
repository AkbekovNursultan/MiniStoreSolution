@page
@model MiniStore.Web.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = "Заказ #@Model.Order?.Id";
}

<h2>Заказ #@Model.Order?.Id</h2>
<p class="text-muted">Дата: @Model.Order?.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>

<table class="table table-bordered" style="max-width: 500px;">
    <thead>
        <tr>
            <th>Товар</th>
            <th>Количество</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Order?.Items ?? [])
        {
            <tr>
                <td>@(Model.ProductNames.TryGetValue(item.ProductId, out var name) ? name : $"Товар #{item.ProductId}")</td>
                <td>@item.Quantity</td>
            </tr>
        }
    </tbody>
</table>

<a href="/Orders" class="btn btn-secondary">Назад</a>
