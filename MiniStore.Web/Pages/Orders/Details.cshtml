@page
@model MiniStore.Web.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = $"Заказ #{Model.Order?.Id}";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Orders" class="btn btn-nm btn-sm">← Назад</a>
    <h1 class="page-title mb-0">Заказ #@Model.Order?.Id</h1>
    <small style="color: var(--text-muted);">@Model.Order?.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
</div>

<div class="nm-card p-4" style="max-width: 560px;">
    <table class="table mb-0">
        <thead>
            <tr style="color: var(--text-muted); font-size: 0.85rem;">
                <th class="border-0 pb-3">Товар</th>
                <th class="border-0 pb-3 text-center">Кол-во</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Order?.Items ?? [])
            {
                <tr>
                    <td class="border-0 py-2 fw-semibold">
                        @(Model.ProductNames.TryGetValue(item.ProductId, out var name) ? name : $"Товар #{item.ProductId}")
                    </td>
                    <td class="border-0 py-2 text-center" style="color: var(--accent); font-weight: 600;">
                        @item.Quantity шт.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
