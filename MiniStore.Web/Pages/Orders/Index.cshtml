@page
@model MiniStore.Web.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Заказы";
}

<h2>Заказы</h2>
<a href="/Orders/Create" class="btn btn-primary mb-3">+ Новый заказ</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Дата</th>
            <th>Товаров</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@order.Items.Count</td>
                <td>
                    <a href="/Orders/Details?id=@order.Id" class="btn btn-sm btn-info">Подробнее</a>
                    <a href="/Orders/Delete?id=@order.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>
