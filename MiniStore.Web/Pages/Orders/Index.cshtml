@page
@model MiniStore.Web.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Мои заказы";
}

<h2>Мои заказы</h2>

@if (!Model.Orders.Any())
{
    <p class="text-muted mt-3">Заказов пока нет. <a href="/">Перейти в каталог</a></p>
}
else
{
    <table class="table mt-3">
        <thead>
            <tr>
                <th>№</th>
                <th>Дата</th>
                <th>Товаров</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td>#@order.Id</td>
                    <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@order.Items.Count поз.</td>
                    <td><a href="/Orders/Details?id=@order.Id" class="btn btn-sm btn-outline-primary">Подробнее</a></td>
                </tr>
            }
        </tbody>
    </table>
}
