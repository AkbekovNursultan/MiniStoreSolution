@page
@model MiniStore.Web.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Удалить товар";
}

<h2>Удалить товар</h2>

<div class="alert alert-warning mt-3" style="max-width: 400px;">
    Вы уверены что хотите удалить товар <strong>@Model.Name</strong> (цена: @Model.Price.ToString("C"))?
</div>

<form method="post" style="max-width: 400px;">
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a href="/Products" class="btn btn-secondary ms-2">Отмена</a>
</form>
