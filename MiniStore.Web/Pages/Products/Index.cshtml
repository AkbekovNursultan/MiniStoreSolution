@page
@model MiniStore.Web.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Товары";
}

<h2>Товары</h2>
<a href="/Products/Create" class="btn btn-primary mb-3">+ Добавить товар</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Цена</th>
            <th>Категория</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Price.ToString("C")</td>
                <td>@(Model.CategoryNames.TryGetValue(product.CategoryId, out var name) ? name : "—")</td>
                <td>
                    <a href="/Products/Edit?id=@product.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <a href="/Products/Delete?id=@product.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>
