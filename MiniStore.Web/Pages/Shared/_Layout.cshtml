@using MiniStore.Web.Models
@{
    var cart = CartSessionHelper.GetCart(Context.Session);
    var cartCount = cart.Sum(i => i.Quantity);
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniStore</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MiniStore.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm mb-4">
            <div class="container">
                <div class="d-flex flex-column me-4">
                    <a class="navbar-brand mb-0 lh-1" asp-page="/Index">MiniStore</a>
                    <small class="navbar-subtitle">онлайн-магазин</small>
                </div>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link @(currentPage == "/Index" ? "nav-link-active" : "")" asp-page="/Index">
                                Каталог
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.StartsWith("/Orders") ? "nav-link-active" : "")" asp-page="/Orders/Index">
                                Мои заказы
                            </a>
                        </li>
                    </ul>

                    <div class="navbar-divider"></div>

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link cart-link @(currentPage.StartsWith("/Cart") ? "nav-link-active" : "")" asp-page="/Cart/Index">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                                Корзина
                                @if (cartCount > 0)
                                {
                                    <span class="cart-badge">@cartCount</span>
                                }
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-4 py-3">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <small style="color: var(--text-muted);">MiniStore &copy; 2026</small>
                <small style="color: var(--text-muted);">Каталог · Корзина · Заказы</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
